APP_ENV=development
APP_PORT=8090
APP_LOG_LEVEL=info
APP_LOG_FORMAT=json

DATABASE_URL=postgres://...
REDIS_URL=redis://...

JWT_SECRET=
JWT_ACCESS_TTL=15m
REFRESH_TTL=168h

# Mail (SMTP)
MAIL_PROVIDER=
MAIL_SMTP_HOST=
MAIL_SMTP_PORT=465
MAIL_SMTP_USER=
MAIL_SMTP_PASSWORD=
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME=

# Storage (avatars)
STORAGE_ENDPOINT=
STORAGE_REGION=us-east-1
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_PRESIGN_TTL=10m
STORAGE_USE_PATH_STYLE=true

# Rate limits
RATE_LOGIN_PER_15M=5
RATE_AVAILABILITY_PER_MIN=60

# Internal (HMAC for downstream services)
INTERNAL_HMAC_SECRET=

DEV_OTP_CODE=
